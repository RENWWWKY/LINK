    "@capawesome/capacitor-file-picker": "^8.0.3",
    "@fastify/cookie": "^11.1.2",
    "@fastify/rate-limit": "^11.1.0",
    "@fastify/static": "^10.1.0",
    "@fastify/websocket": "^11.3.0",
    "fastify": "^5.10.0",
    "fflate": "^0.8.3",
    "idb": "^8.0.0",
    "lucide-vue-next": "^0.468.0",
    "pg": "^8.22.0",
    "pinia": "^2.2.6",
